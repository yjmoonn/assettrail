rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/financeData/{documentId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/analysisPreferences/{documentId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/analysisRuns/{runId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /priceRequests/{market} {
      allow read: if market == "us";
      allow create, update: if request.auth != null
        && market == "us"
        && request.resource.data.keys().hasOnly(["tickers", "updatedAt"])
        && request.resource.data.tickers is list
        && request.resource.data.tickers.size() <= 500
        && request.resource.data.updatedAt is string;
    }
  }
}
